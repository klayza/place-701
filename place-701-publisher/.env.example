OBSIDIAN_VAULT=/home/c1ay/Documents/Obsidian
OBSIDIAN_CONTENT_DIR=Website
OBSIDIAN_ATTACHMENT_DIR=_attachments
# Optional comma-separated extra attachment roots.
# You do not need this for per-folder attachments like trips/foo/attachments/image.jpg.
OBSIDIAN_ATTACHMENT_DIRS=_attachments

DATA_REPO=/home/c1ay/Repos/place-701-data

R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=place-701-media
PUBLIC_MEDIA_URL=https://media.yourdomain.com

OUTPUT_IMAGE_FORMAT=webp
OUTPUT_IMAGE_QUALITY=82
MAX_IMAGE_WIDTH=1800

AUTO_COMMIT=true
AUTO_PUSH=true
# true: only notes with published: true export.
# false: export every note under OBSIDIAN_CONTENT_DIR unless published: false.
PUBLISH_REQUIRE_FLAG=true
